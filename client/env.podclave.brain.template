# Overlay -> ~/.env.podclave.brain  (Podclave auto-sources .env.podclave.* into every shell).
# Identical for the whole org. Fill in from the server install output.
# Identity is NOT here: brain.py reads ~/.podclave/user-email.
export BRAIN_URL="https://YOUR-BRAIN.sprites.app"
export BRAIN_SECRET="REPLACE_WITH_TEAM_SECRET"

# Optional tunables (defaults shown). Auto-recall relevance gate — smart-search
# scores are small/compressed on this engine (good hits ~0.01–0.02), so the recall
# hook drops results below an absolute floor and below a relative band off the top
# hit. Calibrate after observing your brain (one query:  python3 brain.py recall "<q>").
# export BRAIN_RECALL_MIN_SCORE="0.005"   # absolute floor
# export BRAIN_RECALL_REL="0.6"           # keep hits >= top_score * this
